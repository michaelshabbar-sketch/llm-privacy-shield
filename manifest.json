{
  "manifest_version": 3,
  "name": "LLM Privacy Shield",
  "version": "1.0.0",
  "description": "Hide your private data (names, emails, account numbers, secrets) before it is sent to any LLM. The AI still answers; the cloud never sees your real info.",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "LLM Privacy Shield",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "permissions": ["storage", "clipboardWrite"],
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://*.perplexity.ai/*",
        "https://poe.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://huggingface.co/chat/*",
        "https://chat.mistral.ai/*"
      ],
      "js": ["src/redactor.js", "src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
